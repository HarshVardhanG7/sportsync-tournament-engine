{
  "name": "sportsync-tournament-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --parallel --filter @sportsync/api --filter @sportsync/web dev",
    "dev:api": "pnpm --filter @sportsync/api dev",
    "dev:web": "pnpm --filter @sportsync/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm --filter @sportsync/api test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "pnpm --filter @sportsync/api prisma:generate",
    "db:migrate": "pnpm --filter @sportsync/api prisma:migrate",
    "db:studio": "pnpm --filter @sportsync/api prisma:studio",
    "db:seed": "pnpm --filter @sportsync/api prisma:seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  }
}
